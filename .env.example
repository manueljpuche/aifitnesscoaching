# ========================================
# AI Fitness Coaching — Environment Variables
# ========================================
# Copy this file to .env and fill in the values

# --- Application ---
APP_NAME=ai-fitness-coaching
APP_ENV=local
DEBUG=true
LOG_LEVEL=DEBUG
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# --- Database ---
DATABASE_URL=postgresql+asyncpg://fitness:fitness@localhost:5432/fitness
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=15

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# --- AI Provider ("openai" or "groq") ---
AI_PROVIDER=groq

# --- OpenAI ---
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_MODEL_ADVANCED=gpt-4o

# --- Groq (free tier — https://console.groq.com) ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL_DEFAULT=llama-3.1-8b-instant
GROQ_MODEL_ADVANCED=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

AI_DAILY_BUDGET_USD_PER_USER=0.50
AI_DAILY_BUDGET_TOTAL_USD=10.00

# --- MinIO / S3 ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_PROGRESS_PHOTOS=fitness-progress-photos
MINIO_BUCKET_PANTRY_SCANS=fitness-pantry-scans
MINIO_BUCKET_VOICE_NOTES=fitness-voice-notes
MINIO_BUCKET_EXPORTS=fitness-exports
MINIO_BUCKET_BARCODE_SCANS=fitness-barcode-scans

# --- Sentry ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_SAMPLE_RATE=1.0

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# --- n8n Internal Auth ---
N8N_INTERNAL_SECRET=change-me-to-a-random-n8n-secret-at-least-32-chars
